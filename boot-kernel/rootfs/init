#!/bin/bash
# PID 1 — mount pseudo-fs, then interactive bash

export PATH=/bin

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t tmpfs tmpfs /tmp

# /dev is usually mounted by devtmpfs (CONFIG_DEVTMPFS_MOUNT); fallback:
if ! mountpoint -q /dev 2>/dev/null; then
  mkdir -p /dev
  mount -t devtmpfs devtmpfs /dev 2>/dev/null || {
    mknod -m 622 /dev/console c 5 1
    mknod -m 666 /dev/null c 1 3
    mknod -m 666 /dev/tty c 5 0
  }
fi

export HOME=/root
export PS1='boot_kernel# '
cd /

echo "boot_kernel: Linux $(uname -r)"
echo "Root filesystem: initramfs in RAM (proc/sys/dev mounted)"
echo "Utilities: busybox + bash — try: ls /bin  help"
echo "Type 'exit' to halt."
exec /bin/bash --norc -i
